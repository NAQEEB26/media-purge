# ============================
# WP Media Purge — .gitignore
# ============================
# Only distributable plugin files belong in this repo.
# Dev tools, AI assistant configs, and build artifacts stay out.

# Build artifacts
*.zip
*.tar.gz
build/
dist/

# Node / npm (if using @wordpress/scripts for block dev)
node_modules/
package-lock.json
yarn.lock
.npmrc

# Dev tools
.DS_Store
Thumbs.db
*.log
.env
.env.*

# IDE / editors
.vscode/settings.json
.idea/
*.sublime-workspace

# PHP dev tools
vendor/
composer.lock
composer.json
*.phar
CodeSniffer.conf
wpcs/
phpcs-*.txt
phpcbf-*.txt

# Backup files
*.bak
*.orig

# AI assistant configs
.claude/
.qodo/

# Test coverage
coverage/
.phpunit.result.cache
tests/output/

# Planning docs (live in dev-tools/ at workspace level)
FREEMIUM-PLAN.md
*-PLAN.md
*-plan.txt
design*.txt
PLUGIN-GUIDE.md

# WP.org upload staging
svn/
assets-wp-org/
